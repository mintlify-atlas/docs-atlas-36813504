  "keyFeatures": [
    "Algorithmic routine generation based on fitness goals and movement patterns",
    "Real-time biometric step counting via Android foreground service",
    "Training volume progression tracking with historical load comparison",
    "JWT-based stateless authentication with SHA-256 password hashing",
    "Cloudinary CDN integration for profile avatar management",
    "Async FastAPI backend deployed on Vercel with PostgreSQL (Neon)",
    "MVVM architecture with Retrofit for the native Android client",
    "Workout session history with per-exercise progression data"
  ],
  "publicApiSurface": [
